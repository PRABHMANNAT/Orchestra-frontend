# Copy this file to `.env.local` and fill in your OpenAI key.
# `.env.local` is gitignored — it must never be committed.
#
# WARNING: this key is bundled into the client JS. Any visitor to the
# deployed app can extract it from DevTools. Use this setup for LOCAL
# DEVELOPMENT ONLY. In production, route OpenAI calls through a backend
# proxy that holds the key server-side.

VITE_OPENAI_API_KEY=sk-proj-replace-me

# Model used by Socrates and brain features. Defaults to gpt-4o-mini.
VITE_OPENAI_MODEL=gpt-4o-mini
